# GROQ_API_KEY: Required for Llama-3.1-8b-instant inferences via GroqCloud.
GROQ_API_KEY=

# DATABASE_URL: PostgreSQL connection string required for Prisma ORM (direct connection to Supabase).
DATABASE_URL="postgresql://postgres:password@db.supabase.co:5432/postgres"

# SUPABASE_URL: URL of your Supabase project (e.g. https://xxx.supabase.co)
VITE_SUPABASE_URL=

# SUPABASE_ANON_KEY: Public key for client-side usage if needed.
VITE_SUPABASE_ANON_KEY=

# SUPABASE_SERVICE_ROLE_KEY: Admin secret key (bypass RLS) for backend hooks.
SUPABASE_SERVICE_ROLE_KEY=

# JWT_SECRET: Strong secret for signing authentication sessions.
JWT_SECRET="changeme"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ADMIN_2FA_SECRET: The seed used for Super-Admin Two-Factor authentication operations.
# Default base32 fallback is integrated in-app if omitted.
ADMIN_2FA_SECRET="MFRGGZRGJBSWY3DPEB3W64TBNQXDMOJS"

# STRIPE_SECRET_KEY: Optional Stripe API secret key. If present, activates real payment/payout integrations.
STRIPE_SECRET_KEY=
